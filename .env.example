# Devin API (v3 service user token, starts with cog_)
DEVIN_API_KEY=
DEVIN_ORG_ID=

# Target repository (the fork Devin operates on)
TARGET_REPO=oarmstrong95/superset
TARGET_REPO_URL=https://github.com/oarmstrong95/superset

# Optional: cache playbook IDs across runs (auto-created if empty)
SECURITY_PLAYBOOK_ID=
GOVERNANCE_PLAYBOOK_ID=
SECURITY_FIX_PLAYBOOK_ID=
